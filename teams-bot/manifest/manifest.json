{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "{{BOT_APP_ID}}",
  "packageName": "com.gyansys.salescopilot",
  "developer": {
    "name": "GyanSys",
    "websiteUrl": "https://gyansys.com",
    "privacyUrl": "https://gyansys.com/privacy",
    "termsOfUseUrl": "https://gyansys.com/terms"
  },
  "name": {
    "short": "Sales Copilot",
    "full": "Sales Copilot — Salesforce for Teams"
  },
  "description": {
    "short": "Salesforce project updates from Teams",
    "full": "Check project status, update dates, and log notes on Salesforce projects — all without leaving Microsoft Teams. Powered by Agentforce."
  },
  "icons": {
    "color": "icon-color.png",
    "outline": "icon-outline.png"
  },
  "accentColor": "#2563EB",
  "bots": [
    {
      "botId": "{{BOT_APP_ID}}",
      "scopes": ["personal", "team", "groupchat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal", "team", "groupchat"],
          "commands": [
            { "title": "status", "description": "Get a project status card" },
            { "title": "help",   "description": "Show available commands" }
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": []
}
